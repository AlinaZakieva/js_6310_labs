{
  "manifest_version": 3,
  "name": "KAI Spring Theme",
  "version": "1.0",
  "description": "Весенняя тема для сайта kai.ru: светло-зеленый фон и розовые цветочные акценты.",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "host_permissions": [
    "https://kai.ru/*",
    "http://kai.ru/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://kai.ru/*",
        "http://kai.ru/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}